# =========================
# Public Site + SEO Module
# =========================

# Base public URL used for canonical links, metadata, and emails.
NEXT_PUBLIC_SITE_URL=https://your-domain.com
# Enables canonical domain redirect behavior in the frontend.
NEXT_PUBLIC_CANONICAL_REDIRECT=false
# Google Search Console site verification token.
# *NotConifigred
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster site verification token.
# *NotConifigred
NEXT_PUBLIC_BING_SITE_VERIFICATION=
# Google Analytics 4 measurement ID (G-...).
# *NotConifigred
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Google Tag Manager container ID (GTM-...).
# *NotConifigred
NEXT_PUBLIC_GTM_ID=
# Google Ads account ID (AW-...).
# *NotConifigred
NEXT_PUBLIC_GOOGLE_ADS_ID=
# Google Ads conversion label used with conversion tracking events.
# *NotConifigred
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# =====================
# Firebase Web Module
# =====================

# Firebase Web SDK API key.
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
# Firebase Auth domain host only (no protocol, path, or trailing slash).
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
# Firebase project ID used by the client app.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# Firebase Storage bucket used by the client app.
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
# Firebase messaging sender ID for web push.
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
# Firebase app ID for the web app.
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
# Firebase Analytics measurement ID fallback.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
# Firebase Cloud Messaging VAPID key for browser push notifications.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-firebase-vapid-key
# Public VAPID key used by native browser Push API (Safari/Chrome).
# You can reuse the same value as NEXT_PUBLIC_FIREBASE_VAPID_KEY.
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
# Firebase Realtime Database URL (optional if not using RTDB).
# *NotConifigred
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
# Firestore database ID used by client reads/writes.
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=(default)
# reCAPTCHA v3 site key for Firebase App Check.
# *NotConifigred
NEXT_PUBLIC_RECAPTCHA_V3_SITE_KEY=

# =======================
# Firebase Admin Module
# =======================

# Firebase project ID used by server/admin SDK.
FIREBASE_PROJECT_ID=your-project-id
# Firebase service account client email.
# *NotConifigred
FIREBASE_CLIENT_EMAIL=
# Firebase service account private key (escaped newlines if pasted inline).
# *NotConifigred
FIREBASE_PRIVATE_KEY=
# Path to Firebase service account JSON for local/dev tooling.
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-adminsdk.json
# Optional inline/base64 Firebase Admin service account blob used by some deploy targets.
FIREBASE_ADMIN_SERVICE_ACCOUNT=
# Firestore database ID used by server/admin SDK.
FIRESTORE_DATABASE_ID=(default)
# Server-side VAPID public key for direct Web Push delivery.
# Keep this aligned with NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY.
WEB_PUSH_VAPID_PUBLIC_KEY=
# Server-side VAPID private key for direct Web Push delivery.
WEB_PUSH_VAPID_PRIVATE_KEY=
# Contact identifier required by Web Push VAPID details (mailto: or https:// URL).
WEB_PUSH_SUBJECT=mailto:notifications@your-domain.com

# ============================
# Admin + Functions Module
# ============================

# Secret token accepted by cache revalidation endpoints/functions.
REVALIDATE_SECRET=your-revalidate-secret
# Full URL for Next.js revalidation API route.
NEXT_REVALIDATE_ENDPOINT=https://your-domain.com/api/revalidate
# Secret for bootstrap admin claim flow.
ADMIN_BOOTSTRAP_SECRET=your-admin-bootstrap-secret
# Default email for admin bootstrap script.
# *NotConifigred
ADMIN_BOOTSTRAP_EMAIL=
# Default password for admin bootstrap script.
# *NotConifigred
ADMIN_BOOTSTRAP_PASSWORD=
# Password required to reveal integration secrets in admin settings UI.
# *NotConifigred
ADMIN_INTEGRATIONS_VIEW_PASSWORD=
# Primary admin UID for reminder notifications fallback.
# *NotConifigred
NOTIFICATION_PRIMARY_ADMIN_UID=
# Callable/HTTP Cloud Function URL for contact form submissions.
CONTACT_FUNCTION_URL=
# Callable/HTTP Cloud Function URL for meeting booking submissions.
BOOK_MEETING_FUNCTION_URL=

# ===============
# Email Module
# ===============

# Default sender address used by email templates/adapters.
DEFAULT_SENDER_EMAIL=
# Public URL to the logo displayed in email templates.
# *NotConifigred
EMAIL_LOGO_URL=
# Primary recipient email for contact submissions.
# *NotConifigred
CONTACT_RECEIVER_EMAIL=
# API key for Resend email delivery.
# *NotConifigred
RESEND_API_KEY=
# API key for SendGrid email delivery.
# *NotConifigred
SENDGRID_API_KEY=
# API key for Mailgun email delivery.
# *NotConifigred
MAILGUN_API_KEY=
# Mailgun sending domain.
# *NotConifigred
MAILGUN_DOMAIN=
# Gmail App Password for SMTP fallback.
GMAIL_APP_PASSWORD=
# Zoho SMTP host.
ZOHO_SMTP_HOST=smtp.zoho.com
# Zoho SMTP port.
ZOHO_SMTP_PORT=465
# Zoho SMTP secure/TLS mode.
ZOHO_SMTP_SECURE=true
# Zoho SMTP username.
ZOHO_SMTP_USERNAME=
# Zoho SMTP password.
ZOHO_SMTP_PASSWORD=

# ===========================
# Google Calendar Module
# ===========================

# Google service account email for calendar operations.
# *NotConifigred
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Google service account private key (escaped newlines if pasted inline).
# *NotConifigred
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Target calendar ID (use primary or specific calendar ID).
GOOGLE_CALENDAR_ID=primary

# =====================
# AI: Gemini Module
# =====================

# Gemini API key for Saleh-OS flows.
GEMINI_API_KEY=
# Gemini model used by Saleh-OS.
GEMINI_MODEL=gemini-2.5-flash

# =====================
# AI: OpenAI Module
# =====================

# OpenAI API key for Resume Studio/ATS generation.
OPENAI_API_KEY=
# OpenAI model used by Resume Studio/ATS.
OPENAI_MODEL=gpt-5.2

# ========================
# Resume Export Module
# ========================

# PDF export renderer strategy: auto | chromium | pdf-lib.
RESUME_EXPORT_RENDERER=auto
# Base URL used for server-side print route fetch during PDF export.
RESUME_EXPORT_BASE_URL=
