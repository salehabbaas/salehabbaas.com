rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isPublicOrUnlistedPublished(visibility, publishedAt) {
      return (visibility == 'public' || visibility == 'unlisted') && publishedAt != null;
    }

    function isPublishedAndNotDeleted(status, isDeleted) {
      return (status == null || status == 'published') && isDeleted != true;
    }

    function isPmProject(data) {
      return data.module == 'project-management'
        && data.ownerId is string
        && (data.status == 'active' || data.status == 'archived');
    }

    function isOwnedPmProject(projectId) {
      return projectId is string
        && exists(/databases/$(database)/documents/projects/$(projectId))
        && isPmProject(get(/databases/$(database)/documents/projects/$(projectId)).data)
        && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }

    match /contentItems/{contentItemId} {
      allow read, write: if isAdmin();

      match /variants/{variantId} {
        allow read: if isAdmin() || isPublicOrUnlistedPublished(resource.data.visibility, resource.data.publishedAt);
        allow create, update, delete: if isAdmin();

        match /metrics/{metricId} {
          allow read: if isAdmin() || isPublicOrUnlistedPublished(
            get(/databases/$(database)/documents/contentItems/$(contentItemId)/variants/$(variantId)).data.visibility,
            get(/databases/$(database)/documents/contentItems/$(contentItemId)/variants/$(variantId)).data.publishedAt
          );
          allow write: if isAdmin();
        }
      }
    }

    match /creatorSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /creatorTemplates/{docId} {
      allow read, write: if isAdmin();
    }

    match /hookLibrary/{docId} {
      allow read, write: if isAdmin();
    }

    match /ctaLibrary/{docId} {
      allow read, write: if isAdmin();
    }

    match /jobApplications/{docId} {
      allow read, write: if isAdmin();
    }

    match /jobTrackerSettings/{docId} {
      allow read, write: if isAdmin();
    }

    match /newsletterSubscribers/{subscriberId} {
      allow create: if request.resource.data.email is string
        && request.resource.data.status == 'pending'
        && request.resource.data.source is string;
      allow update, read, delete: if isAdmin();
    }

    match /contactSubmissions/{docId} {
      allow create: if request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.message is string;
      allow read, update, delete: if isAdmin();
    }

    match /analyticsEvents/{docId} {
      allow create: if request.resource.data.name is string;
      allow read, update, delete: if isAdmin();
    }

    match /siteContent/{docId} {
      allow read: if docId != 'integrations' || isAdmin();
      allow write: if isAdmin();
    }

    match /adminSettings/{docId} {
      allow read, write: if isAdmin();
    }

    match /experiences/{docId} {
      allow read: if isPublishedAndNotDeleted(resource.data.status, resource.data.isDeleted);
      allow write: if isAdmin();
    }

    match /services/{docId} {
      allow read: if isPublishedAndNotDeleted(resource.data.status, resource.data.isDeleted);
      allow write: if isAdmin();
    }

    match /certificates/{docId} {
      allow read: if isPublishedAndNotDeleted(resource.data.status, resource.data.isDeleted);
      allow write: if isAdmin();
    }

    match /socialLinks/{docId} {
      allow read: if isPublishedAndNotDeleted(resource.data.status, resource.data.isDeleted);
      allow write: if isAdmin();
    }

    match /projects/{docId} {
      allow read: if (
          isPmProject(resource.data)
          && isAdmin()
          && resource.data.ownerId == request.auth.uid
        ) || (
          !isPmProject(resource.data)
          && (isAdmin() || (resource.data.status == 'published' && resource.data.isDeleted != true))
        );

      allow create: if isAdmin() && (
          (isPmProject(request.resource.data) && request.resource.data.ownerId == request.auth.uid)
          || !isPmProject(request.resource.data)
        );

      allow update, delete: if isAdmin() && (
          (
            isPmProject(resource.data)
            && resource.data.ownerId == request.auth.uid
            && isPmProject(request.resource.data)
            && request.resource.data.ownerId == resource.data.ownerId
          )
          || !isPmProject(resource.data)
        );
    }

    match /boards/{docId} {
      allow read: if isAdmin() && isOwnedPmProject(resource.data.projectId);
      allow create: if isAdmin() && isOwnedPmProject(request.resource.data.projectId);
      allow update: if isAdmin()
        && isOwnedPmProject(resource.data.projectId)
        && request.resource.data.projectId == resource.data.projectId
        && isOwnedPmProject(request.resource.data.projectId);
      allow delete: if isAdmin() && isOwnedPmProject(resource.data.projectId);
    }

    match /tasks/{docId} {
      allow read: if isAdmin() && isOwnedPmProject(resource.data.projectId);
      allow create: if isAdmin() && isOwnedPmProject(request.resource.data.projectId);
      allow update: if isAdmin()
        && isOwnedPmProject(resource.data.projectId)
        && request.resource.data.projectId == resource.data.projectId
        && isOwnedPmProject(request.resource.data.projectId);
      allow delete: if isAdmin() && isOwnedPmProject(resource.data.projectId);

      match /notificationsSent/{notificationId} {
        allow read, write: if isAdmin() && isOwnedPmProject(get(/databases/$(database)/documents/tasks/$(docId)).data.projectId);
      }
    }

    match /activity/{docId} {
      allow read, delete: if isAdmin() && isOwnedPmProject(resource.data.projectId);
      allow create: if isAdmin() && isOwnedPmProject(request.resource.data.projectId);
      allow update: if isAdmin()
        && isOwnedPmProject(resource.data.projectId)
        && request.resource.data.projectId == resource.data.projectId
        && isOwnedPmProject(request.resource.data.projectId);
    }

    match /users/{userId} {
      match /settings/{docId} {
        allow read, write: if isAdmin() && request.auth.uid == userId;
      }
    }

    match /blogPosts/{docId} {
      allow read: if isAdmin() || (resource.data.status == 'published' && resource.data.isDeleted != true);
      allow write: if isAdmin();
    }

    match /mediaAssets/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookingSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookings/{docId} {
      allow read, write: if isAdmin();
    }

    match /blockedSlots/{docId} {
      allow read, write: if isAdmin();
    }

    match /bookingSlotLocks/{docId} {
      allow read, write: if isAdmin();
    }

    match /creatorReminders/{docId} {
      allow read, write: if isAdmin();
    }

    match /linkedinStudioProfiles/{docId} {
      allow read, write: if isAdmin();
    }

    match /linkedinStudioPosts/{docId} {
      allow read, write: if isAdmin();

      match /versions/{versionId} {
        allow read, write: if isAdmin();
      }
    }

    match /auditLogs/{docId} {
      allow read, write: if isAdmin();
    }

    match /adminAccessLogs/{docId} {
      allow read, write: if isAdmin();
    }

    match /siteVersionSnapshots/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
